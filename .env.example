# dnsmasq-viewer environment variables
# See README.md for full documentation

# HTTP listen address (default: 0.0.0.0)
#HOST=0.0.0.0

# HTTP listen port (default: 8000)
#PORT=8000

# Path to the dnsmasq lease file
LEASEFILE=/var/lib/misc/dnsmasq.leases

# Override the system hostname
#HOSTNAME=

# Path to the reboot-required marker file (set to empty string to disable)
#REBOOT_REQUIRED=/var/run/reboot-required

# Comma-separated list of allowed IPv4/IPv6 networks in CIDR notation
# Use 0.0.0.0/0 to allow all connections
ALLOWED_NETWORKS=192.168.0.0/16,127.0.0.1

# Enable detailed HTTP request logging (leave empty to disable)
#DEBUG=1
